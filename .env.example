# Box app credentials (required by Phase 0)
BOX_CLIENT_ID=your_box_client_id
BOX_CLIENT_SECRET=your_box_client_secret
BOX_ENTERPRISE_ID=your_enterprise_id

# Human reviewer (collaborator on /DevTool-Loop/)
REVIEWER_EMAIL=reviewer@example.com

# Base URL for webhook target + OAuth redirect
ORCHESTRATOR_HOST=http://localhost:3000

# GitHub OAuth (for per-user repo creation)
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# AWS Bedrock — replaces ANTHROPIC_API_KEY for Claude access
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514
# BEDROCK_REGION=us-east-1   # optional, defaults to AWS_REGION or us-east-1
# AWS credentials are resolved by the SDK (env, ~/.aws/credentials, IAM role)

# --- Additional vars for later phases ---
# APIFY_TOKEN=
# BOX_WEBHOOK_PRIMARY_KEY=
# BOX_WEBHOOK_SECONDARY_KEY=
# GITHUB_TOKEN=
# GITHUB_ORG=
# GITHUB_REPO_VISIBILITY=private
